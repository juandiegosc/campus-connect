# Copiar a .env y ajustar. No subir el .env real al repositorio.

# Bases de datos (mismas credenciales para todas las instancias Postgres)
DB_USER=campus
DB_PASSWORD=campus

# RabbitMQ
RABBITMQ_USER=guest
RABBITMQ_PASS=guest

# JWT (emitido por Identity, validado por Gateway y servicios)
JWT_ISSUER=campusconnect
JWT_AUDIENCE=campusconnect-clients
# Clave de firma simetrica (HS256). Generar una larga y aleatoria, minimo 32 bytes.
JWT_SIGNING_KEY=cambiar-esta-clave-por-una-larga-y-aleatoria-de-al-menos-32-bytes
